-- ============================================================================
--  deploy/seed.sql.example â€” SAFE, schema-only bootstrap (NO real data)
-- ============================================================================
-- The real deploy/seed.sql (a full production dump containing PII + password
-- hashes + a live API key) is GITIGNORED and must NEVER be committed.
--
-- This template seeds the `users` table the application assumes already exists,
-- plus ONE temporary bootstrap administrator so a fresh deployment can log in
-- immediately (no manual hashing step). Every other table is created automatically
-- by ensureLibrarySchema() on the first request. Copy this to deploy/seed.sql when
-- building a release.
--
-- âš  TEMPORARY ADMINISTRATOR â€” first-deployment convenience only.
--   Username: SDO_Quirino    Password: SDOQ2026!
--   The client must change BOTH from inside the LMS right after the first login
--   (My Account â†’ change password; Settings â†’ Users â†’ rename/replace this account).
-- ============================================================================

-- (v1.1) CREATE DATABASE removed: docker-entrypoint seeds into ${DB_NAME}; pinning `library_sys` here broke DB_NAME overrides.
-- (v1.1) USE removed for the same reason.

CREATE TABLE IF NOT EXISTS `users` (
  `id`             INT AUTO_INCREMENT PRIMARY KEY,
  `username`       VARCHAR(255) NOT NULL UNIQUE,            -- login email
  `password`       VARCHAR(255) NOT NULL,                   -- bcrypt hash, NEVER plaintext
  `full_name`      VARCHAR(255) NULL,
  `role`           VARCHAR(20)  NOT NULL DEFAULT 'viewer',  -- admin | staff | viewer
  `status`         VARCHAR(20)  NOT NULL DEFAULT 'pending', -- pending | approved | rejected
  `is_active`      TINYINT(1)   NOT NULL DEFAULT 1,
  `classification` VARCHAR(50)  NOT NULL DEFAULT 'individual',
  `contact`        VARCHAR(50)  NULL,
  `lrn`            VARCHAR(12)  NULL,
  `school_name`    VARCHAR(255) NULL,
  `grade_level`    VARCHAR(100) NULL,
  `profile_image`  VARCHAR(500) NULL,
  `avatar_id`      VARCHAR(120) NULL,
  `created_at`     DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- â”€â”€ Temporary bootstrap administrator (idempotent) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
-- Created ONLY on a fresh database, and ONLY if the username does not already exist
-- (INSERT IGNORE + the UNIQUE username key) â€” so it never duplicates the account and
-- never overwrites a password the admin has already changed.
-- The value below is a bcrypt hash of 'SDOQ2026!'; the app checks it with
-- password_verify() (the same algorithm). Change the password after first login.
INSERT IGNORE INTO `users` (username, password, full_name, role, status, is_active)
VALUES ('SDO_Quirino', '$2y$10$RTBhKH4HCXUmJBQ29AVASOwaZCWkC9oMtqu2RjWph6awGoNtdcUPK', 'SDO Administrator', 'admin', 'approved', 1);
