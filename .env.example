# ============================================================================
#  Environment template — copy to .env and set REAL values.  .env is gitignored.
#  Never commit a filled-in .env. Use strong, unique values for a government system.
# ============================================================================

# ── Database (read by config/database.php) ─────────────────────────────────
# The application connects as DB_USER — a database-SCOPED account, never root.
DB_HOST=db                     # service/host name (compose network: "db")
DB_NAME=library_sys
DB_USER=lms_user
DB_PASS=change-me-strong-password

# ── MySQL root (compose only: container init, phpMyAdmin, backups) ──────────
# Not used by the app itself. Rotate after first boot. Keep phpMyAdmin OFF in prod.
MYSQL_ROOT_PASSWORD=change-me-strong-root-password

# ── Backups (read by backup.sh) ────────────────────────────────────────────
DB_CONTAINER=lms_db            # name of the MySQL container to dump from
KEEP=14                        # how many rotated backups to retain

# ── Outbound email / SMTP (registration verification codes) ─────────────────
# Optional here: SMTP can also be configured in-app (Settings → Notifications →
# Email (SMTP), stored in library_settings). Env values OVERRIDE the in-app ones.
# For Gmail:
#   1. The Google account must have 2-Step Verification enabled.
#   2. Create an App Password: Google Account → Security → 2-Step Verification
#      → App passwords. Use the 16-character value below (NOT the normal password).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=tls            # tls = STARTTLS on 587 · ssl = implicit TLS on 465
# SMTP_USER=your-library@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM_EMAIL=your-library@gmail.com
# SMTP_FROM_NAME=SDO Quirino Library

# ============================================================================
#  Application-level secrets are NOT stored here.
# ----------------------------------------------------------------------------
#  • The SMS gateway API key, sender name, and message templates live in the
#    database table `library_settings` and are configured from the in-app
#    Settings page (admin only). Do NOT place them in this file or in the repo.
#  • There is no separate session secret — PHP manages session IDs; cookies are
#    hardened in auth.php (HttpOnly, SameSite=Lax, Secure on HTTPS).
#  • TLS is terminated in front of the app (reverse proxy / Cloudflare Tunnel);
#    tunnel credentials live outside the repo (~/.cloudflared), never committed.
# ============================================================================

# ── CI only (used by the E2E workflow against a disposable DB; not for prod) ─
# E2E_USER=admin@e2e.test
# E2E_PASS=change-me-in-ci-secrets
