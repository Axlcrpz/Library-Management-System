# Attachments here are served only through api/library_handler.php?action=announcement_file
# (auth + published/expiry checks). Block all direct web access.
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
